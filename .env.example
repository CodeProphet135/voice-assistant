# --- LLM (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=minimal
OPENAI_MAX_OUTPUT_TOKENS=1024

# --- Speech (Deepgram) ---
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# --- Database ---
DATABASE_URL=postgresql+asyncpg://va:va@localhost:5432/voice_assistant

# --- Observability ---
# Leave empty to fall back to a console span exporter. To view traces in Jaeger,
# start it with `docker compose --profile observability up -d jaeger` and set this
# to http://localhost:4318 (Jaeger UI: http://localhost:16686).
OTEL_EXPORTER_OTLP_ENDPOINT=
